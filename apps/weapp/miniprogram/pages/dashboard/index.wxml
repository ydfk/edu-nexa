<view class="page">
  <view class="hero">
    <view class="hero-title">{{homeHeroTitle}}</view>
    <view class="hero-subtitle">{{homeHeroSubtitle}}</view>
  </view>

  <view class="section">
    <view class="section-title">公告</view>
    <view class="empty-card">{{homeAnnouncement}}</view>
  </view>

  <view class="section">
    <view class="section-title">机构介绍</view>
    <swiper class="banner-swiper" autoplay circular indicator-dots interval="4500">
      <block wx:for="{{banners}}" wx:key="id">
        <swiper-item>
          <view class="banner-card">
            <image class="banner-image" mode="aspectFill" src="{{item.image}}" />
            <view class="banner-content">
              <view class="list-title">{{item.title}}</view>
              <view class="list-meta">{{item.subtitle}}</view>
            </view>
          </view>
        </swiper-item>
      </block>
    </swiper>
  </view>

  <view class="section">
    <view class="section-title">今日概览</view>
    <view class="grid">
      <block wx:for="{{metrics}}" wx:key="label">
        <view class="card">
          <view class="card-label">{{item.label}}</view>
          <view class="card-value">{{item.value}}</view>
        </view>
      </block>
    </view>
  </view>

  <view class="section">
    <view class="section-title">
      {{activeRole === "teacher" ? "教师待办" : activeRole === "guardian" ? "家长提示" : "登录提示"}}
    </view>
    <view class="list">
      <block wx:for="{{tips}}" wx:key="*this">
        <view class="list-item">
          <view class="list-title">{{item}}</view>
        </view>
      </block>
    </view>
  </view>
</view>
