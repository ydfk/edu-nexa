<view class="page">
  <view class="hero">
    <view class="hero-title">教师记录，监护人查看。</view>
    <view class="hero-subtitle">用餐登记和作业记录是当前两条主链路。</view>
  </view>

  <view class="section">
    <view class="section-title">今日概览</view>
    <view class="grid">
      <block wx:for="{{metrics}}" wx:key="label">
        <view class="card">
          <view class="card-label">{{item.label}}</view>
          <view class="card-value">{{item.value}}</view>
        </view>
      </block>
    </view>
  </view>

  <view class="section">
    <view class="section-title">待办提醒</view>
    <view class="list">
      <block wx:for="{{todos}}" wx:key="*this">
        <view class="list-item">
          <view class="list-title">{{item}}</view>
        </view>
      </block>
    </view>
  </view>
</view>
