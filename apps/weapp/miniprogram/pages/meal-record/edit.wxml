<view class="page safe-bottom">
  <view class="card">
    <view class="form-group">
      <view class="form-label {{readOnly ? '' : 'form-label--required'}}">选择学生</view>
      <van-cell wx:if="{{!readOnly}}" title="{{selectedStudent.name || '请选择学生'}}" is-link bindtap="openStudentPicker" title-class="{{selectedStudent.name ? '' : 'text-secondary'}}" />
      <van-cell wx:else title="{{selectedStudent.name || '未设置'}}" />
    </view>
    <view class="form-group">
      <view class="form-label {{readOnly ? '' : 'form-label--required'}}">服务日期</view>
      <van-cell wx:if="{{!readOnly}}" title="{{serviceDate}}" is-link bindtap="openDatePicker" />
      <van-cell wx:else title="{{serviceDate}}" />
    </view>
    <view class="form-group">
      <view class="form-label {{readOnly ? '' : 'form-label--required'}}">用餐状态</view>
      <van-radio-group wx:if="{{!readOnly}}" value="{{status}}" bind:change="onStatusChange" direction="horizontal">
        <van-radio name="completed" icon-size="36rpx">已用餐</van-radio>
        <van-radio name="absent" icon-size="36rpx">未用餐</van-radio>
      </van-radio-group>
      <view wx:else class="detail-value">{{statusText || "未设置"}}</view>
    </view>
    <view class="form-group">
      <view class="form-label">照片记录</view>
      <view wx:if="{{fileList.length > 0 || !readOnly}}" class="detail-attachments">
        <view
          wx:for="{{fileList}}"
          wx:key="name"
          class="detail-attachment"
          bindtap="onPreviewAttachment"
          data-index="{{index}}"
        >
          <view
            wx:if="{{!readOnly}}"
            class="detail-attachment__delete"
            catchtap="onDeleteAttachment"
            data-index="{{index}}"
          >
            <van-icon name="cross" size="24rpx" color="#5f6d63" />
          </view>
          <van-icon name="photo-o" size="34rpx" color="#34845f" />
          <text class="detail-attachment__name">{{item.name}}</text>
        </view>
        <van-uploader
          wx:if="{{!readOnly && fileList.length < 9}}"
          class="detail-attachment-uploader"
          file-list="{{[]}}"
          max-count="{{9 - fileList.length}}"
          accept="image"
          show-upload="{{false}}"
          preview-size="72"
        >
          <view class="detail-attachment detail-attachment--upload" bindtap="chooseImages">
            <van-icon name="photograph" size="40rpx" color="#b9c3bc" />
            <text class="detail-attachment__upload-text">拍照/选图</text>
          </view>
        </van-uploader>
      </view>
      <view wx:if="{{fileList.length === 0 && readOnly}}" class="detail-value detail-value--muted">暂无照片</view>
    </view>
    <view class="form-group">
      <view class="form-label">备注</view>
      <textarea wx:if="{{!readOnly}}" class="form-textarea" value="{{remark}}" bindinput="onRemarkInput" placeholder="选填备注信息" maxlength="200" />
      <view wx:else class="detail-value {{remark ? '' : 'detail-value--muted'}}">
        {{remark || "暂无备注"}}
      </view>
    </view>
  </view>
  <view class="mt-lg flex gap-sm" wx:if="{{!readOnly}}">
    <button class="btn btn--primary btn--block btn--round" bindtap="onSubmit" disabled="{{submitting}}">
      {{isEdit ? '保存修改' : '提交记录'}}
    </button>
  </view>
  <view class="mt-sm" wx:if="{{isEdit && !readOnly}}">
    <button class="btn btn--ghost btn--block btn--round" bindtap="onDelete">删除记录</button>
  </view>
  <van-popup show="{{showStudentPicker}}" position="bottom" round bind:close="closeStudentPicker">
    <van-picker columns="{{studentColumns}}" bind:confirm="onStudentConfirm" bind:cancel="closeStudentPicker" show-toolbar title="选择学生" />
  </van-popup>
  <van-calendar show="{{showDatePicker}}" bind:close="closeDatePicker" bind:confirm="onDateConfirm" color="#07C160" />
  <van-dialog id="van-dialog" />
</view>
