.detail-value {
  min-height: 44rpx;
  padding: 8rpx 0;
  font-size: 26rpx;
  line-height: 1.7;
  color: var(--color-text);
}

.detail-value--muted {
  color: var(--color-text-secondary);
}

.detail-images {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 8rpx;
}

.meal-upload-slot {
  width: 144rpx;
  height: 144rpx;
  margin-top: 8rpx;
  border-radius: 16rpx;
  background: #f7f8fa;
  border: 2rpx dashed #d7dce2;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
}

.meal-upload-slot__icon {
  font-size: 40rpx;
  color: #8b949e;
}

.meal-upload-slot__text {
  font-size: 22rpx;
  color: #8b949e;
}

.detail-image {
  width: 144rpx;
  height: 144rpx;
  border-radius: 16rpx;
  background: var(--color-bg-secondary);
}
