.detail-value {
  min-height: 44rpx;
  padding: 8rpx 0;
  font-size: 26rpx;
  line-height: 1.7;
  color: var(--color-text);
}

.detail-value--muted {
  color: var(--color-text-secondary);
}

.detail-images,
.detail-attachments {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 8rpx;
}

.detail-attachment-uploader {
  width: 144rpx;
  min-height: 144rpx;
}

.detail-image {
  width: 144rpx;
  height: 144rpx;
  border-radius: 16rpx;
  background: var(--color-bg-secondary);
}

.detail-attachment {
  position: relative;
  width: 144rpx;
  min-height: 144rpx;
  padding: 18rpx 14rpx;
  border-radius: 16rpx;
  background: #f3f7f5;
  border: 1rpx solid rgba(52, 132, 95, 0.14);
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
}

.detail-attachment--upload {
  background: #f5f7f8;
  border: 1rpx solid rgba(185, 195, 188, 0.28);
}

.detail-attachment__delete {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  width: 32rpx;
  height: 32rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.92);
  display: flex;
  align-items: center;
  justify-content: center;
}

.detail-attachment__name {
  width: 100%;
  font-size: 20rpx;
  line-height: 1.4;
  color: var(--color-text-secondary);
  text-align: center;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.detail-attachment__upload-text {
  font-size: 20rpx;
  line-height: 1.4;
  color: #9aa59d;
  text-align: center;
}
