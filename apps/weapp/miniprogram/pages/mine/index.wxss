.mine-page {
  background: linear-gradient(180deg, #f7f8fa 0%, #f2f5f4 100%);
}

.mine-panel {
  display: flex;
  align-items: center;
  gap: var(--spacing-md);
  padding: var(--spacing-lg);
  border-radius: 32rpx;
  background: linear-gradient(145deg, #ffffff 0%, #f3fbf6 100%);
  box-shadow: 0 18rpx 44rpx rgba(15, 59, 45, 0.08);
}

.mine-panel__avatar {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 112rpx;
  height: 112rpx;
  border-radius: 50%;
  background: #f3f6f4;
  flex-shrink: 0;
}

.mine-panel__body {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  align-items: flex-start;
}

.mine-panel__login-row {
  width: 100%;
  display: flex;
  justify-content: flex-start;
}

.mine-panel__name {
  font-size: 36rpx;
  font-weight: 700;
  color: #173b2b;
}

.mine-panel__meta {
  margin-top: 12rpx;
  font-size: 24rpx;
  color: #61736a;
}

button.mine-panel__login {
  margin-top: 12rpx;
  margin-left: 0;
  margin-right: 0;
  padding: 0 32rpx;
  min-width: 220rpx;
  width: auto;
  align-self: flex-start;
  display: inline-flex;
}

.mine-footer {
  text-align: center;
  padding: var(--spacing-xl) 0;
}
