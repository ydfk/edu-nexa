.mx-lg {
  margin-left: var(--spacing-lg);
  margin-right: var(--spacing-lg);
}

.mine-header {
  display: flex;
  align-items: center;
  margin: var(--spacing-lg);
  padding: 32rpx var(--spacing-lg);
  gap: var(--spacing-md);
  border-radius: 32rpx;
  background: linear-gradient(145deg, #edf9f2 0%, #c8edda 100%);
  box-shadow: 0 4rpx 24rpx rgba(7, 193, 96, 0.1);
}

.mine-avatar {
  width: 116rpx;
  height: 116rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.8);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.mine-avatar--active {
  background: rgba(255, 255, 255, 0.85);
}

.mine-info {
  flex: 1;
  min-width: 0;
}

.mine-name {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  color: #1a3d2b;
}

.mine-desc {
  margin-top: 6rpx;
  font-size: 24rpx;
  color: #4a7060;
}

.mine-login-wrap {
  margin-top: -8rpx;
}

.mine-login-action {
  width: 100%;
}

.mine-meta {
  margin-top: 10rpx;
  display: flex;
  align-items: center;
  gap: 14rpx;
  flex-wrap: wrap;
}

.mine-meta__tag {
  flex-shrink: 0;
}

.mine-meta__phone {
  font-size: 24rpx;
  line-height: 1.2;
  color: var(--color-text-secondary);
}

.mine-roles {
  display: flex;
  gap: var(--spacing-sm);
  flex-wrap: wrap;
}

.mine-role-chip {
  padding: var(--spacing-sm) var(--spacing-md);
  border-radius: var(--radius-full);
  background: var(--color-bg-secondary);
  font-size: 26rpx;
  color: var(--color-text);
}

.mine-role-chip--active {
  background: var(--color-primary-light);
  color: var(--color-primary);
  font-weight: 500;
}

.mine-footer {
  text-align: center;
  padding: var(--spacing-xl) 0;
}
