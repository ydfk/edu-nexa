<view class="page safe-bottom mine-page">
  <view class="mine-panel">
    <view class="mine-panel__avatar">
      <van-icon name="{{avatarIcon}}" size="64rpx" color="{{avatarColor}}" />
    </view>
    <view class="mine-panel__body">
      <view class="mine-panel__name">{{headerName}}</view>
      <view class="mine-panel__meta" wx:if="{{loggedIn}}">{{phone}} · {{roleName}}</view>
      <button wx:if="{{!loggedIn}}" class="btn btn--primary btn--small btn--round mine-panel__login" bindtap="goLogin">登录</button>
    </view>
  </view>

  <block wx:if="{{loggedIn}}">
    <view class="section">
      <view class="section-header">
        <text class="section-title">系统设置</text>
      </view>
      <van-cell-group>
        <van-cell title="个人信息" is-link bindtap="goProfile" />
        <van-cell title="修改密码" is-link bindtap="goPassword" />
        <van-cell title="系统信息" is-link bindtap="goAbout" />
      </van-cell-group>
    </view>

    <view class="mt-lg">
      <button class="btn btn--ghost btn--block btn--round" bindtap="onLogout">退出登录</button>
    </view>
  </block>

  <view class="mine-footer text-xs text-secondary">v1.0.0</view>
  <van-dialog id="van-dialog" />
</view>
