.records-toolbar {
  padding: 14rpx 16rpx;
  border-radius: 24rpx;
  background: #ffffff;
  box-shadow: var(--shadow-card);
}

.records-toolbar__main {
  width: 100%;
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  gap: 14rpx;
}

.records-toolbar__date {
  flex: 1;
  min-width: 0;
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.records-toolbar__arrow {
  width: 48rpx;
  height: 48rpx;
  border-radius: 14rpx;
  background: #edf9f2;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #1a3d2b;
}

.records-toolbar__date-main {
  flex: 1;
  min-width: 0;
}

.records-toolbar__date-text {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--color-text);
}

.records-toolbar__date-sub {
  margin-top: 2rpx;
  font-size: 20rpx;
  color: var(--color-text-secondary);
}

.records-toolbar__tabs {
  flex-shrink: 0;
  display: flex;
  gap: 6rpx;
  padding: 6rpx;
  border-radius: 18rpx;
  background: #e8f4ed;
}

.records-toolbar__tab {
  min-width: 88rpx;
  padding: 10rpx 16rpx;
  border-radius: 14rpx;
  text-align: center;
  font-size: 22rpx;
  color: #5f6d63;
}

.records-toolbar__tab--active {
  background: #ffffff;
  color: #06a050;
  font-weight: 600;
  box-shadow: 0 8rpx 18rpx rgba(7, 193, 96, 0.12);
}

.records-layout {
  display: flex;
  gap: 12rpx;
  height: calc(100vh - 236rpx);
  padding: 14rpx 28rpx 24rpx;
  box-sizing: border-box;
}

.records-sidebar {
  width: 184rpx;
  border-radius: 22rpx;
  background: #f4f7f5;
  padding: 8rpx;
  box-sizing: border-box;
}

.records-student {
  padding: 14rpx 12rpx;
  border-radius: 16rpx;
}

.records-student--active {
  background: #ffffff;
  box-shadow: 0 10rpx 22rpx rgba(15, 118, 110, 0.12);
}

.records-student__name {
  font-size: 24rpx;
  font-weight: 600;
  color: var(--color-text);
  line-height: 1.35;
}

.records-student__meta {
  margin-top: 4rpx;
  font-size: 18rpx;
  line-height: 1.45;
  color: var(--color-text-secondary);
}

.records-content {
  flex: 1;
  min-width: 0;
}

.record-card {
  padding: 18rpx;
  border-radius: 18rpx;
  background: #ffffff;
  box-shadow: var(--shadow-card);
  margin-bottom: 12rpx;
}

.record-card--clickable {
  position: relative;
}

.record-card__body {
  position: relative;
}

.record-card--clickable::after {
  content: "";
  position: absolute;
  top: 28rpx;
  right: 24rpx;
  width: 12rpx;
  height: 12rpx;
  border-top: 2rpx solid var(--color-text-secondary);
  border-right: 2rpx solid var(--color-text-secondary);
  transform: rotate(45deg);
}

.record-card__header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24rpx;
  padding-right: 24rpx;
}

.record-card__title {
  font-size: 25rpx;
  font-weight: 600;
  color: var(--color-text);
}

.record-card__meta {
  margin-top: 6rpx;
  font-size: 20rpx;
  color: var(--color-text-secondary);
}

.record-card__summary {
  margin-top: 8rpx;
  font-size: 22rpx;
  line-height: 1.55;
  color: var(--color-text);
}

.record-card__remark {
  margin-top: 8rpx;
  padding-top: 8rpx;
  border-top: 1rpx solid rgba(5, 90, 52, 0.08);
  font-size: 21rpx;
  line-height: 1.6;
  color: var(--color-text-secondary);
}

.record-card__images {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-top: 10rpx;
}

.record-card__thumb {
  width: 104rpx;
  min-height: 104rpx;
  border-radius: 12rpx;
  padding: 10rpx 8rpx;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
}

.record-card__thumb--image {
  background: #edf7f1;
  border: 1rpx solid rgba(52, 132, 95, 0.14);
}

.record-card__thumb--pdf {
  background: #fff7f6;
  border: 1rpx solid rgba(196, 61, 51, 0.12);
}

.record-card__thumb--file {
  background: #fff7f6;
  border: 1rpx solid rgba(196, 61, 51, 0.12);
}

.record-card__thumb-name {
  width: 100%;
  font-size: 18rpx;
  line-height: 1.35;
  color: var(--color-text-secondary);
  text-align: center;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.records-empty {
  padding-top: 120rpx;
}
