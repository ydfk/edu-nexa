<view class="page">
  <van-cell-group inset>
    <van-cell
      title="日期"
      value="{{selectedDate}}"
      is-link
      bind:click="handleOpenDateCalendar"
    />
    <van-cell title="已完成" value="{{stats[0] ? stats[0].value : '0'}}" />
    <van-cell title="待处理" value="{{stats[1] ? stats[1].value : '0'}}" />
    <van-cell title="请假" value="{{stats[2] ? stats[2].value : '0'}}" />
  </van-cell-group>

  <van-tabs
    wx:if="{{students.length > 0}}"
    custom-class="block-gap"
    active="{{activeStudentTab}}"
    swipeable
    animated
    bind:change="handleStudentTabChange"
  >
    <block wx:for="{{students}}" wx:key="id">
      <van-tab title="{{item.name}}" />
    </block>
  </van-tabs>

  <van-panel wx:if="{{currentRecord}}" custom-class="block-gap" title="{{currentRecord.studentName}}">
    <van-cell-group border="{{false}}">
      <van-cell title="学校" value="{{currentRecord.schoolInfo || '-'}}" />
      <van-cell title="校区" value="{{currentRecord.campusName || '-'}}" />
      <van-cell title="状态" value="{{currentRecord.statusLabel}}" />
    </van-cell-group>
  </van-panel>

  <van-cell-group wx:if="{{!canManage && currentRecord}}" custom-class="block-gap" inset>
    <van-field label="备注" readonly value="{{currentRecord.remark || '-'}}" />
    <van-field label="图片" readonly value="{{currentRecord.imageUrls.length}}张" />
  </van-cell-group>

  <van-uploader
    wx:if="{{!canManage && currentRecord && currentRecord.fileList.length > 0}}"
    custom-class="block-gap uploader-block"
    file-list="{{currentRecord.fileList}}"
    preview-full-image
    show-upload="{{false}}"
    deletable="{{false}}"
  />

  <view wx:if="{{canManage && editorDraft}}">
    <van-radio-group
      custom-class="block-gap"
      value="{{editorDraft.status}}"
      bind:change="handleMealStatusChange"
    >
      <van-cell-group inset>
        <van-cell clickable data-name="pending" bind:click="handleMealStatusChange">
          <view slot="title">待处理</view>
          <van-radio name="pending" slot="right-icon" />
        </van-cell>
        <van-cell clickable data-name="completed" bind:click="handleMealStatusChange">
          <view slot="title">已完成</view>
          <van-radio name="completed" slot="right-icon" />
        </van-cell>
        <van-cell clickable data-name="leave" bind:click="handleMealStatusChange">
          <view slot="title">请假</view>
          <van-radio name="leave" slot="right-icon" />
        </van-cell>
      </van-cell-group>
    </van-radio-group>

    <van-cell-group custom-class="block-gap" inset>
      <van-field
        label="备注"
        type="textarea"
        autosize
        value="{{editorDraft.remark}}"
        placeholder="备注"
        bind:change="handleMealRemarkInput"
      />
    </van-cell-group>

    <van-uploader
      custom-class="block-gap uploader-block"
      file-list="{{editorDraft.fileList}}"
      multiple
      max-count="3"
      preview-full-image
      bind:after-read="handleAfterReadImage"
      bind:delete="handleDeleteImage"
    />

    <van-submit-bar
      button-text="保存"
      custom-class="submit-bar"
      safe-area-inset-bottom
      bind:submit="handleSaveRecord"
    />
  </view>

  <view class="block-gap" wx:if="{{students.length === 0}}">
    <van-empty description="无" />
  </view>

  <van-calendar
    show="{{showDateCalendar}}"
    color="#07c160"
    poppable
    bind:close="handleCloseDateCalendar"
    bind:confirm="handleConfirmDate"
  />
</view>
