<view class="page">
  <view class="hero">
    <view class="hero-title">晚餐登记要快，状态要准。</view>
    <view class="hero-subtitle">到校后优先完成请假、用餐、异常备注三项确认。</view>
  </view>

  <view class="section">
    <view class="section-title">今日用餐记录</view>
    <view class="list">
      <block wx:for="{{records}}" wx:key="studentName">
        <view class="list-item">
          <view class="list-title">{{item.studentName}}</view>
          <view class="list-meta">{{item.campusName}}</view>
          <view class="tag">{{item.status}}</view>
          <view class="list-meta">{{item.remark}}</view>
        </view>
      </block>
    </view>
  </view>
</view>
