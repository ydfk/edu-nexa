.school-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.school-card {
  padding: 24rpx;
  border-radius: 24rpx;
  background: #ffffff;
  box-shadow: var(--shadow-card);
}

.school-card__header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
}

.school-card__title-wrap {
  min-width: 0;
}

.school-card__title {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--color-text);
}

.school-card__meta {
  margin-top: 6rpx;
  font-size: 22rpx;
  color: var(--color-text-secondary);
}

.school-card__actions,
.grade-block__actions,
.class-row__actions {
  display: flex;
  align-items: center;
  gap: 18rpx;
  flex-shrink: 0;
}

.grade-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-top: 20rpx;
}

.grade-block {
  padding: 18rpx;
  border-radius: 20rpx;
  background: linear-gradient(180deg, #f8fbf9 0%, #f1f6f3 100%);
  border: 1rpx solid rgba(7, 193, 96, 0.1);
}

.grade-block__header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 18rpx;
}

.grade-block__title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--color-text);
}

.grade-block__meta {
  margin-top: 4rpx;
  font-size: 20rpx;
  color: var(--color-text-secondary);
}

.class-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  margin-top: 16rpx;
}

.class-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  padding: 16rpx 18rpx;
  border-radius: 16rpx;
  background: #ffffff;
}

.class-row__info {
  min-width: 0;
}

.class-row__name {
  font-size: 24rpx;
  font-weight: 600;
  color: var(--color-text);
}

.class-row__meta {
  margin-top: 4rpx;
  font-size: 20rpx;
  color: var(--color-text-secondary);
}

.grade-block__footer,
.school-card__footer {
  margin-top: 14rpx;
}

.class-empty,
.school-empty {
  margin-top: 16rpx;
  font-size: 22rpx;
  color: var(--color-text-secondary);
}

.action-link {
  font-size: 22rpx;
  color: #0b8d4a;
}

.action-link--danger {
  color: var(--color-danger);
}

.subtle-link {
  font-size: 22rpx;
  color: #0b8d4a;
}
