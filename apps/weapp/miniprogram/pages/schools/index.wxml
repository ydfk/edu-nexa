<view class="page safe-bottom">
  <!-- 学校列表 -->
  <view wx:if="{{schools.length > 0}}">
    <van-collapse value="{{activeSchool}}" bind:change="onSchoolCollapse" accordion>
      <van-collapse-item wx:for="{{schools}}" wx:key="id" name="{{item.id}}" title="{{item.name}}">
        <view slot="value" class="text-sm text-secondary">{{item.gradeCount || 0}}个年级</view>

        <!-- 年级列表 -->
        <view class="grade-list">
          <view class="grade-item" wx:for="{{item.grades}}" wx:for-item="grade" wx:key="id">
            <view class="flex flex-between" bindtap="toggleGrade" data-school-id="{{item.id}}" data-grade-id="{{grade.id}}">
              <text class="text-base font-medium">{{grade.name}}</text>
              <text class="text-sm text-secondary">{{grade.classCount || 0}}个班级</text>
            </view>

            <!-- 班级列表 -->
            <view class="class-list" wx:if="{{grade.expanded}}">
              <view class="class-item flex flex-between" wx:for="{{grade.classes}}" wx:for-item="cls" wx:key="id">
                <view>
                  <text class="text-sm">{{cls.name}}</text>
                  <text class="text-xs text-secondary ml-xs">（{{cls.studentCount || 0}}人）</text>
                </view>
                <view class="flex gap-xs" wx:if="{{canEdit}}">
                  <text class="text-sm text-primary" bindtap="editClass" data-class="{{cls}}" data-grade-id="{{grade.id}}">编辑</text>
                  <text class="text-sm text-danger" bindtap="removeClass" data-id="{{cls.id}}">删除</text>
                </view>
              </view>
              <view class="mt-sm" wx:if="{{canEdit}}">
                <button class="btn btn--outline btn--small" bindtap="addClass" data-grade-id="{{grade.id}}">+ 添加班级</button>
              </view>
            </view>

            <view class="flex gap-xs mt-xs" wx:if="{{canEdit}}">
              <text class="text-sm text-primary" bindtap="editGrade" data-grade="{{grade}}" data-school-id="{{item.id}}">编辑</text>
              <text class="text-sm text-danger" bindtap="removeGrade" data-id="{{grade.id}}">删除</text>
            </view>
          </view>

          <view class="mt-sm" wx:if="{{canEdit}}">
            <button class="btn btn--outline btn--small" bindtap="addGrade" data-school-id="{{item.id}}">+ 添加年级</button>
          </view>
        </view>

        <view class="flex gap-sm mt-md" wx:if="{{canEdit}}">
          <button class="btn btn--outline btn--small" bindtap="editSchool" data-school="{{item}}">编辑学校</button>
          <button class="btn btn--small" style="color: var(--color-danger);" bindtap="removeSchool" data-id="{{item.id}}">删除学校</button>
        </view>
      </van-collapse-item>
    </van-collapse>
  </view>
  <van-empty wx:else description="暂无学校数据" />

  <view class="fab" wx:if="{{canEdit}}" bindtap="addSchool">
    <text class="fab-icon">+</text>
  </view>

  <!-- 编辑弹窗 -->
  <van-popup show="{{showEditPopup}}" position="bottom" round bind:close="closeEditPopup" custom-style="padding: 32rpx;">
    <view class="text-lg font-bold mb-md">{{editTitle}}</view>
    <view class="form-group">
      <view class="form-label form-label--required">名称</view>
      <input class="form-input" value="{{editName}}" bindinput="onEditNameInput" placeholder="请输入名称" />
    </view>
    <view class="mt-lg">
      <button class="btn btn--primary btn--block btn--round" bindtap="onEditConfirm">确定</button>
    </view>
  </van-popup>

  <van-dialog id="van-dialog" />
</view>
