<view class="page safe-bottom">
  <view wx:if="{{schools.length > 0}}">
    <view class="school-list">
      <view class="school-card" wx:for="{{schools}}" wx:key="id">
        <view class="school-card__header">
          <view class="school-card__title-wrap">
            <view class="school-card__title">{{item.name}}</view>
            <view class="school-card__meta">{{item.gradeCount || 0}}个年级 · {{item.classTotal || 0}}个班级</view>
          </view>
          <view class="school-card__actions" wx:if="{{canEdit}}">
            <text class="action-link" bindtap="editSchool" data-school="{{item}}">编辑</text>
            <text class="action-link action-link--danger" bindtap="removeSchool" data-id="{{item.id}}">删除</text>
          </view>
        </view>

        <view class="grade-list" wx:if="{{item.grades.length > 0}}">
          <view class="grade-block" wx:for="{{item.grades}}" wx:for-item="grade" wx:key="id">
            <view class="grade-block__header">
              <view>
                <view class="grade-block__title">{{grade.name}}</view>
                <view class="grade-block__meta">{{grade.classCount || 0}}个班级</view>
              </view>
              <view class="grade-block__actions" wx:if="{{canEdit}}">
                <text class="action-link" bindtap="editGrade" data-grade="{{grade}}">编辑</text>
                <text class="action-link action-link--danger" bindtap="removeGrade" data-id="{{grade.id}}">删除</text>
              </view>
            </view>

            <view class="class-list" wx:if="{{grade.classes.length > 0}}">
              <view class="class-row" wx:for="{{grade.classes}}" wx:for-item="cls" wx:key="id">
                <view class="class-row__info">
                  <view class="class-row__name">{{cls.name}}</view>
                  <view class="class-row__meta">{{cls.studentCount || 0}}人</view>
                </view>
                <view class="class-row__actions" wx:if="{{canEdit}}">
                  <text class="action-link" bindtap="editClass" data-class="{{cls}}" data-grade="{{grade}}" data-school="{{item}}">编辑</text>
                  <text class="action-link action-link--danger" bindtap="removeClass" data-id="{{cls.id}}">删除</text>
                </view>
              </view>
            </view>
            <view class="class-empty" wx:else>暂无班级</view>

            <view class="grade-block__footer" wx:if="{{canEdit}}">
              <text class="subtle-link" bindtap="addClass" data-grade="{{grade}}" data-school="{{item}}">+ 添加班级</text>
            </view>
          </view>
        </view>
        <view class="school-empty" wx:else>暂无年级与班级</view>

        <view class="school-card__footer" wx:if="{{canEdit}}">
          <text class="subtle-link" bindtap="addGrade">+ 添加年级</text>
        </view>
      </view>
    </view>
  </view>
  <van-empty wx:else description="暂无学校数据" />

  <view class="fab" wx:if="{{canEdit}}" bindtap="addSchool">
    <text class="fab-icon">+</text>
  </view>

  <!-- 编辑弹窗 -->
  <van-popup show="{{showEditPopup}}" position="bottom" round bind:close="closeEditPopup" custom-style="padding: 32rpx;">
    <view class="text-lg font-bold mb-md">{{editTitle}}</view>
    <view class="form-group">
      <view class="form-label form-label--required">名称</view>
      <input class="form-input" value="{{editName}}" bindinput="onEditNameInput" placeholder="请输入名称" />
    </view>
    <view class="mt-lg">
      <button class="btn btn--primary btn--block btn--round" bindtap="onEditConfirm">确定</button>
    </view>
  </van-popup>

  <van-dialog id="van-dialog" />
</view>
