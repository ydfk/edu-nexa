.login-page {
  min-height: 100vh;
  padding: var(--spacing-lg);
  box-sizing: border-box;
  background: linear-gradient(180deg, #f7f8fa 0%, #f2f5f4 100%);
}

.login-brand {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 88rpx 0 56rpx;
}

.login-brand__logo {
  width: 144rpx;
  height: 144rpx;
}

.login-brand__title {
  margin-top: 24rpx;
  font-size: 40rpx;
  font-weight: 700;
  color: #173b2b;
}

.login-brand__subtitle {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: var(--color-text-secondary);
}

.login-panel {
  padding: 36rpx 32rpx 40rpx;
  border-radius: 28rpx;
  background: #ffffff;
  box-shadow: 0 16rpx 40rpx rgba(15, 59, 45, 0.06);
}

.login-input {
  background: #f4f6f5;
  border: 2rpx solid #e6ece8;
}

.login-submit {
  margin-top: var(--spacing-sm);
}

.login-privacy {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  margin-top: var(--spacing-lg);
}

.login-privacy__text {
  display: inline-flex;
  align-items: center;
}
