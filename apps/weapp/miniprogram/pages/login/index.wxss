.login-page {
  min-height: 100vh;
  padding: var(--spacing-lg);
  box-sizing: border-box;
  background: var(--color-bg);
}

.login-hero {
  margin-top: var(--spacing-md);
  padding: 36rpx 32rpx 32rpx;
  border-radius: 32rpx;
  background: linear-gradient(145deg, #edf9f2 0%, #c8edda 100%);
  box-shadow: 0 4rpx 24rpx rgba(7, 193, 96, 0.1);
}

.login-hero__head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
}

.login-hero__left {
  flex: 1;
  min-width: 0;
}

.login-hero__eyebrow {
  display: inline-block;
  padding: 8rpx 22rpx;
  border-radius: 999rpx;
  background: rgba(7, 193, 96, 0.18);
  font-size: 22rpx;
  color: #06a050;
  font-weight: 500;
}

.login-app-name {
  margin-top: 18rpx;
  font-size: 44rpx;
  font-weight: 700;
  color: #1a3d2b;
  line-height: 1.2;
}

.login-app-subtitle {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #4a7060;
}

.login-hero__art {
  width: 150rpx;
  height: 150rpx;
  flex-shrink: 0;
}

.login-slogan {
  margin-top: 20rpx;
  font-size: 26rpx;
  line-height: 1.7;
  color: #4a7060;
}

.login-panel {
  margin-top: var(--spacing-lg);
  padding: 36rpx 32rpx 40rpx;
  border-radius: 32rpx;
  background: rgba(255, 255, 255, 0.96);
  box-shadow: 0 20rpx 48rpx rgba(22, 42, 61, 0.08);
}

.login-panel__desc {
  margin-top: 12rpx;
  font-size: 24rpx;
  line-height: 1.7;
  color: var(--color-text-secondary);
}

.login-input {
  background: #f4f7f7;
  border: 2rpx solid #e5ece8;
}

.login-submit {
  margin-top: var(--spacing-sm);
}

.login-divider {
  display: flex;
  align-items: center;
  gap: var(--spacing-sm);
  margin: var(--spacing-lg) 0;
}

.login-divider__line {
  flex: 1;
  height: 2rpx;
  background: #e5ece8;
}

.login-divider__text {
  font-size: 22rpx;
  color: var(--color-text-secondary);
}

.login-privacy {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  margin-top: var(--spacing-lg);
}

.login-tip {
  margin-top: var(--spacing-md);
  text-align: center;
  line-height: 1.7;
}
