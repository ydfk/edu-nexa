.login-page {
  min-height: 100vh;
  padding: var(--spacing-lg);
  box-sizing: border-box;
  background:
    radial-gradient(circle at top right, rgba(7, 193, 96, 0.16), transparent 32%),
    linear-gradient(180deg, #f6fbf8 0%, #f3f6fb 100%);
}

.login-hero {
  position: relative;
  overflow: hidden;
  margin-top: var(--spacing-md);
  padding: 44rpx;
  border-radius: 36rpx;
  background: linear-gradient(135deg, #10261c 0%, #184530 58%, #236648 100%);
  box-shadow: 0 20rpx 48rpx rgba(16, 38, 28, 0.18);
}

.login-hero__badge {
  display: inline-flex;
  align-items: center;
  height: 52rpx;
  padding: 0 20rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.14);
  color: rgba(255, 255, 255, 0.9);
  font-size: 22rpx;
}

.login-brand {
  display: flex;
  align-items: center;
  gap: var(--spacing-md);
  margin-top: 28rpx;
}

.login-logo {
  width: 132rpx;
  height: 132rpx;
  border-radius: 32rpx;
  background: rgba(255, 255, 255, 0.14);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.login-brand__text {
  flex: 1;
  min-width: 0;
}

.login-app-name {
  font-size: 44rpx;
  font-weight: 700;
  color: #ffffff;
  line-height: 1.2;
}

.login-app-subtitle {
  margin-top: 6rpx;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.72);
}

.login-slogan {
  margin-top: var(--spacing-sm);
  font-size: 26rpx;
  line-height: 1.7;
  color: rgba(255, 255, 255, 0.88);
}

.login-hero__art {
  width: 100%;
  height: 220rpx;
  margin-top: var(--spacing-md);
  opacity: 0.98;
}

.login-panel {
  margin-top: var(--spacing-lg);
  padding: 36rpx 32rpx 40rpx;
  border-radius: 32rpx;
  background: rgba(255, 255, 255, 0.96);
  box-shadow: 0 20rpx 48rpx rgba(22, 42, 61, 0.08);
}

.login-panel__desc {
  margin-top: 12rpx;
  font-size: 24rpx;
  line-height: 1.7;
  color: var(--color-text-secondary);
}

.login-input {
  background: #f4f7f7;
  border: 2rpx solid #e5ece8;
}

.login-submit {
  margin-top: var(--spacing-sm);
}

.login-divider {
  display: flex;
  align-items: center;
  gap: var(--spacing-sm);
  margin: var(--spacing-lg) 0;
}

.login-divider__line {
  flex: 1;
  height: 2rpx;
  background: #e5ece8;
}

.login-divider__text {
  font-size: 22rpx;
  color: var(--color-text-secondary);
}

.login-privacy {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  margin-top: var(--spacing-lg);
}

.login-tip {
  margin-top: var(--spacing-md);
  text-align: center;
  line-height: 1.7;
}
