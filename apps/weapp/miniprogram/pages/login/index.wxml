<view class="login-page safe-bottom">
  <view class="login-brand">
    <image class="login-brand__logo" src="/assets/logo-study-record-mini.png" mode="aspectFit" />
    <view class="login-brand__title">作业用餐小记</view>
    <view class="login-brand__subtitle">账号登录</view>
  </view>

  <view class="login-panel">
    <view class="form-group">
      <view class="form-label">账号</view>
      <input class="form-input login-input" type="number" maxlength="11" value="{{phone}}" placeholder="请输入账号" bindinput="onPhoneInput" />
    </view>
    <view class="form-group">
      <view class="form-label">密码</view>
      <input class="form-input login-input" password="{{true}}" value="{{password}}" placeholder="请输入密码" bindinput="onPasswordInput" />
    </view>

    <button class="btn btn--primary btn--block btn--round login-submit" bindtap="onPasswordLogin" loading="{{submitting}}" disabled="{{submitting}}">
      登录
    </button>

    <view class="login-privacy">
      <van-checkbox value="{{agreedPrivacy}}" shape="round" icon-size="32rpx" bind:change="onPrivacyChange" />
      <view class="login-privacy__text" bindtap="togglePrivacy">
        <text class="text-sm text-secondary">
          我已阅读并同意
          <text class="text-primary" catchtap="goPrivacy">《隐私协议》</text>
        </text>
      </view>
    </view>
  </view>
</view>
