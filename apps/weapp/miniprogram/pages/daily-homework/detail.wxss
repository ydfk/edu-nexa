/* 使用全局样式 */

.quick-selector {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: var(--spacing-md);
  min-height: 88rpx;
  padding: 0 var(--spacing-md);
  border-radius: var(--radius-md);
  background: var(--color-bg-secondary);
  box-sizing: border-box;
}

.quick-selector__value {
  flex: 1;
  min-width: 0;
  color: var(--color-text);
}

.quick-selector__action {
  flex-shrink: 0;
  color: var(--color-primary);
  font-size: 24rpx;
  font-weight: 600;
}

.subject-radio-group {
  display: flex;
  flex-wrap: wrap;
  gap: var(--spacing-sm);
  margin-top: var(--spacing-sm);
}

.scope-picker__empty {
  margin-top: var(--spacing-sm);
  font-size: 24rpx;
  color: var(--color-text-secondary);
}

.attachment-section {
  margin-top: 16rpx;
}

.attachment-section:first-of-type {
  margin-top: 12rpx;
}

.attachment-section__title {
  margin-bottom: 10rpx;
  font-size: 22rpx;
  font-weight: 600;
  color: #617168;
}

.detail-attachments {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 12rpx;
}

.detail-attachment-uploader {
  width: 144rpx;
  min-height: 144rpx;
}

.detail-attachment {
  position: relative;
  width: 144rpx;
  min-height: 144rpx;
  padding: 18rpx 14rpx;
  border-radius: 16rpx;
  background: #f3f7f5;
  border: 1rpx solid rgba(52, 132, 95, 0.14);
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
}

.detail-attachment--upload {
  background: #f5f7f8;
  border: 1rpx solid rgba(185, 195, 188, 0.28);
}

.detail-attachment--upload-image {
  background: linear-gradient(180deg, #f3faf6 0%, #edf6f0 100%);
  border-color: rgba(52, 132, 95, 0.18);
}

.detail-attachment--upload-file {
  background: linear-gradient(180deg, #faf5f4 0%, #f7f0ee 100%);
  border-color: rgba(196, 61, 51, 0.14);
}

.detail-attachment__delete {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  width: 32rpx;
  height: 32rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.92);
  display: flex;
  align-items: center;
  justify-content: center;
}

.detail-attachment__name {
  width: 100%;
  font-size: 20rpx;
  line-height: 1.4;
  color: var(--color-text-secondary);
  text-align: center;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.detail-attachment__upload-text {
  font-size: 20rpx;
  line-height: 1.4;
  color: #9aa59d;
  text-align: center;
}

.detail-attachment__upload-text--image {
  color: #5f8a74;
}

.detail-attachment__upload-text--file {
  color: #a67a73;
}
