<view class="page safe-bottom">
  <view class="card">
    <!-- 班级范围 -->
    <view class="form-group">
      <view class="form-label form-label--required">学校/年级/班级</view>
      <picker mode="selector" range="{{scopeOptions}}" range-key="label" value="{{selectedScopeIndex}}" bindchange="onScopeChange">
        <view class="quick-selector">
          <view class="quick-selector__value {{selectedClass.id ? '' : 'text-secondary'}}">
            {{selectedClass.id ? (selectedSchool.name + '/' + selectedGrade.name + '/' + selectedClass.name) : '请选择学校/年级/班级'}}
          </view>
          <view class="quick-selector__action">下拉选择</view>
        </view>
      </picker>
    </view>

    <!-- 日期 -->
    <view class="form-group">
      <view class="form-label form-label--required">日期</view>
      <van-cell title="{{serviceDate}}" is-link bindtap="openDatePicker" />
    </view>

    <!-- 科目 -->
    <view class="form-group">
      <view class="form-label form-label--required">科目</view>
      <van-radio-group wx:if="{{subjectColumns.length > 0}}" value="{{subject}}" bind:change="onSubjectChange" direction="horizontal" custom-class="subject-radio-group">
        <van-radio wx:for="{{subjectColumns}}" wx:key="value" name="{{item.value}}" icon-size="34rpx">
          {{item.text}}
        </van-radio>
      </van-radio-group>
      <view wx:else class="scope-picker__empty">暂无科目，请先配置常用科目</view>
    </view>

    <!-- 内容 -->
    <view class="form-group">
      <view class="form-label form-label--required">作业内容</view>
      <textarea class="form-textarea" value="{{content}}" bindinput="onContentInput" placeholder="请输入作业内容" maxlength="1000" style="min-height: 300rpx;" />
    </view>

    <!-- 附件 -->
    <view class="form-group">
      <view class="form-label">附件</view>
      <view class="attachment-section">
        <view class="attachment-section__title">图片附件</view>
        <view class="detail-attachments">
          <view
            wx:for="{{imageAttachmentCards}}"
            wx:key="index"
            class="detail-attachment"
            bindtap="onPreviewAttachment"
            data-index="{{item.index}}"
          >
            <view
              class="detail-attachment__delete"
              catchtap="onDeleteAttachment"
              data-index="{{item.index}}"
            >
              <van-icon name="cross" size="24rpx" color="#5f6d63" />
            </view>
            <van-icon name="{{item.iconName}}" size="36rpx" color="{{item.iconColor}}" />
            <text class="detail-attachment__name">{{item.name}}</text>
          </view>
          <view
            wx:if="{{fileList.length < 9}}"
            class="detail-attachment detail-attachment--upload detail-attachment--upload-image"
            bindtap="chooseImageAttachments"
          >
            <van-icon name="photo-o" size="40rpx" color="#7bb697" />
            <text class="detail-attachment__upload-text detail-attachment__upload-text--image">上传图片</text>
          </view>
        </view>
      </view>
      <view class="attachment-section">
        <view class="attachment-section__title">文件附件</view>
        <view class="detail-attachments">
          <view
            wx:for="{{fileAttachmentCards}}"
            wx:key="index"
            class="detail-attachment"
            bindtap="onPreviewAttachment"
            data-index="{{item.index}}"
          >
            <view
              class="detail-attachment__delete"
              catchtap="onDeleteAttachment"
              data-index="{{item.index}}"
            >
              <van-icon name="cross" size="24rpx" color="#5f6d63" />
            </view>
            <van-icon name="{{item.iconName}}" size="36rpx" color="{{item.iconColor}}" />
            <text class="detail-attachment__name">{{item.name}}</text>
          </view>
          <view
            wx:if="{{fileList.length < 9}}"
            class="detail-attachment detail-attachment--upload detail-attachment--upload-file"
            bindtap="chooseFileAttachments"
          >
            <van-icon name="description" size="40rpx" color="#c89a95" />
            <text class="detail-attachment__upload-text detail-attachment__upload-text--file">上传文件</text>
          </view>
        </view>
      </view>
    </view>

  </view>

  <view class="mt-lg">
    <button class="btn btn--primary btn--block btn--round" bindtap="onSubmit" disabled="{{submitting}}">
      {{isEdit ? '保存修改' : '发布作业'}}
    </button>
  </view>
  <view class="mt-sm" wx:if="{{isEdit}}">
    <button class="btn btn--ghost btn--block btn--round" bindtap="onDelete">删除作业</button>
  </view>

  <!-- 日期选择 -->
  <van-calendar
    show="{{showDatePicker}}"
    bind:close="closeDatePicker"
    bind:confirm="onDateConfirm"
    color="#07C160"
  />

  <van-dialog id="van-dialog" />
</view>
