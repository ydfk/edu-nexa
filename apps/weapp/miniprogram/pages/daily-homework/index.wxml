<view class="page page--no-pad safe-bottom">
  <view class="homework-datebar">
    <view class="homework-datebar__inner">
      <view class="homework-datebar__arrow" bindtap="prevDay">
        <van-icon name="arrow-left" />
      </view>
      <view class="homework-datebar__text" bindtap="openCalendar">{{dateDisplay}}</view>
      <view class="homework-datebar__arrow" bindtap="nextDay">
        <van-icon name="arrow" />
      </view>
    </view>
  </view>

  <view class="homework-toolbar mt-sm" wx:if="{{canEdit}}">
    <view class="homework-toolbar__action" bindtap="onPrintHomework">打印作业</view>
  </view>

  <view class="homework-groups mt-sm" wx:if="{{homeworkGroups.length > 0}}">
    <view class="school-card" wx:for="{{homeworkGroups}}" wx:key="key">
      <view class="school-card__header">
        <view class="school-card__title-wrap">
          <view class="school-card__title">{{item.schoolName}}</view>
          <view class="school-card__meta">{{item.gradeName}} {{item.className}}</view>
        </view>
      </view>

      <view class="grade-list">
        <view class="grade-block" wx:for="{{item.items}}" wx:for-item="homework" wx:key="id" bindtap="goDetail" data-id="{{homework.id}}">
          <view class="grade-block__header">
            <view>
              <view class="grade-block__title">{{homework.subject || "未分类"}}</view>
              <view class="grade-block__meta" wx:if="{{homework.teacherName}}">教师：{{homework.teacherName}}</view>
            </view>
            <view class="grade-block__action">
              <text class="grade-block__action-text">{{canEdit ? "点击编辑" : "点击查看"}}</text>
              <van-icon name="arrow" size="28rpx" color="#93a39a" />
            </view>
          </view>
          <view class="homework-content">{{homework.contentText}}</view>
          <view class="homework-attachments" wx:if="{{homework.attachmentItems && homework.attachmentItems.length > 0}}">
            <view
              wx:for="{{homework.attachmentItems}}"
              wx:for-item="attachment"
              wx:key="key"
              class="homework-attachment {{attachment.type === 'image' ? 'homework-attachment--image' : 'homework-attachment--file'}}"
              catchtap="openAttachment"
              data-index="{{index}}"
              data-attachments="{{homework.attachments}}"
            >
              <van-icon name="{{attachment.type === 'image' ? 'photo-o' : 'description'}}" size="36rpx" color="{{attachment.type === 'image' ? '#34845f' : '#c43d33'}}" />
              <text class="homework-attachment__name">{{attachment.name}}</text>
            </view>
          </view>
          <view class="homework-remark" wx:if="{{homework.remark}}">备注：{{homework.remark}}</view>
        </view>
      </view>
    </view>
  </view>
  <view class="mt-sm" wx:else>
    <van-empty description="当天暂无作业" image="search" />
  </view>

  <view class="fab" wx:if="{{canEdit}}" bindtap="onAdd">
    <text class="fab-icon">+</text>
  </view>

  <van-calendar
    show="{{showCalendar}}"
    bind:close="closeCalendar"
    bind:confirm="onCalendarConfirm"
    default-date="{{calendarDate}}"
    color="#07C160"
  />
</view>
