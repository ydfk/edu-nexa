.section--compact {
  padding-top: var(--spacing-sm);
}

.feature-grid {
  display: flex;
  flex-wrap: wrap;
  margin: 0 -8rpx;
}

.feature-grid__item {
  width: 33.3333%;
  padding: 8rpx;
  box-sizing: border-box;
}

.feature-grid__card {
  min-height: 176rpx;
  border-radius: 24rpx;
  background: #ffffff;
  box-shadow: var(--shadow-card);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 14rpx;
  padding: 20rpx 0;
  box-sizing: border-box;
}

.feature-grid__icon {
  width: 84rpx;
  height: 84rpx;
  border-radius: 24rpx;
  background: #edf9f2;
  display: flex;
  align-items: center;
  justify-content: center;
}

.feature-grid__title {
  padding: 0 16rpx;
  font-size: 24rpx;
  font-weight: 600;
  line-height: 1.35;
  color: var(--color-text);
  text-align: center;
}
