<view class="page safe-bottom">
  <view class="card">
    <view class="form-group">
      <view class="form-label form-label--required">当前密码</view>
      <input class="form-input" value="{{currentPassword}}" bindinput="onInput" data-field="currentPassword" placeholder="请输入当前密码" password="{{true}}" />
    </view>

    <view class="form-group">
      <view class="form-label form-label--required">新密码</view>
      <input class="form-input" value="{{newPassword}}" bindinput="onInput" data-field="newPassword" placeholder="请输入新密码" password="{{true}}" />
    </view>

    <view class="form-group">
      <view class="form-label form-label--required">确认新密码</view>
      <input class="form-input" value="{{confirmPassword}}" bindinput="onInput" data-field="confirmPassword" placeholder="请再次输入新密码" password="{{true}}" />
    </view>
  </view>

  <view class="mt-lg">
    <button class="btn btn--primary btn--block btn--round" bindtap="onSubmit" disabled="{{submitting}}">确认修改</button>
  </view>
</view>
