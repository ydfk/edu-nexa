<view class="page page--no-pad safe-bottom">
  <view class="home-hero">
    <view class="home-hero__content">
      <view class="home-hero__eyebrow">{{heroBadge}}</view>
      <view class="home-hero__title">{{heroTitle}}</view>
      <view class="home-hero__desc">{{heroDesc}}</view>
      <view class="home-intro-list">
        <view class="home-intro-card" wx:for="{{introPoints}}" wx:key="id">
          <view class="home-intro-card__title">{{item.title}}</view>
          <view class="home-intro-card__desc">{{item.desc}}</view>
        </view>
      </view>
    </view>
    <image class="home-hero__art" src="{{heroImage}}" mode="aspectFit" />
  </view>

  <view class="section mx-lg">
    <view class="section-header">
      <text class="section-title">最近动态</text>
    </view>
    <view class="list" wx:if="{{recentItems.length > 0}}">
      <view class="list-item" wx:for="{{recentItems}}" wx:key="id">
        <view class="list-content">
          <view class="list-title">{{item.title}}</view>
          <view class="list-desc">{{item.desc}}</view>
        </view>
        <view class="tag tag--{{item.tagType}}">{{item.tagText}}</view>
      </view>
    </view>
    <van-empty wx:else description="暂无动态" image="search" />
  </view>
</view>
