.mx-lg {
  margin-left: var(--spacing-lg);
  margin-right: var(--spacing-lg);
}

.home-hero {
  position: relative;
  overflow: hidden;
  margin: var(--spacing-lg);
  padding: 44rpx 36rpx 200rpx;
  border-radius: 36rpx;
  background: linear-gradient(135deg, #0f231b 0%, #1e5f41 68%, #3d8e68 100%);
  box-shadow: 0 20rpx 48rpx rgba(16, 38, 28, 0.18);
}

.home-hero__content {
  flex: 1;
  min-width: 0;
  position: relative;
  z-index: 2;
}

.home-hero__eyebrow {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.74);
}

.home-hero__title {
  margin-top: var(--spacing-sm);
  font-size: 42rpx;
  line-height: 1.3;
  font-weight: 700;
  color: #ffffff;
}

.home-hero__desc {
  max-width: 460rpx;
  margin-top: var(--spacing-sm);
  font-size: 24rpx;
  line-height: 1.8;
  color: rgba(255, 255, 255, 0.88);
}

.home-hero__art {
  position: absolute;
  right: 10rpx;
  bottom: 0;
  width: 300rpx;
  height: 220rpx;
  opacity: 0.98;
}

.home-intro-list {
  margin-top: var(--spacing-lg);
  display: flex;
  flex-direction: column;
  gap: var(--spacing-sm);
}

.home-intro-card {
  max-width: 460rpx;
  padding: 22rpx 24rpx;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.14);
  backdrop-filter: blur(12rpx);
}

.home-intro-card__title {
  font-size: 28rpx;
  font-weight: 600;
  color: #ffffff;
}

.home-intro-card__desc {
  margin-top: 8rpx;
  font-size: 24rpx;
  line-height: 1.7;
  color: rgba(255, 255, 255, 0.78);
}
