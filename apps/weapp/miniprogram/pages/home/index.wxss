.home-page {
  background: linear-gradient(180deg, #f7f8fa 0%, #f1f5f3 100%);
}

.home-panel {
  display: flex;
  flex-direction: column;
  gap: var(--spacing-md);
  padding: var(--spacing-lg);
  border-radius: 32rpx;
  background: linear-gradient(145deg, #ffffff 0%, #f3fbf6 100%);
  box-shadow: 0 18rpx 44rpx rgba(15, 59, 45, 0.08);
}

.home-panel__header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: var(--spacing-md);
}

.home-panel__body {
  flex: 1;
  min-width: 0;
}

.home-panel__title {
  font-size: 40rpx;
  font-weight: 700;
  color: #163829;
}

.home-panel__meta {
  margin-top: 12rpx;
  font-size: 24rpx;
  color: #5d6f66;
}

.home-panel__date {
  font-size: 26rpx;
  color: #2f5846;
}

.home-panel__logo {
  width: 120rpx;
  height: 120rpx;
  flex-shrink: 0;
}

.home-metric-grid,
.home-summary-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: var(--spacing-sm);
}

.home-summary-card {
  padding: 24rpx;
  border-radius: 24rpx;
  background: #f4f6f5;
  border: 2rpx solid #e6ece8;
}

.home-summary-card__label {
  font-size: 24rpx;
  color: var(--color-text-secondary);
}

.home-summary-card__value {
  margin-top: 10rpx;
  font-size: 36rpx;
  font-weight: 700;
  color: #173b2b;
}
