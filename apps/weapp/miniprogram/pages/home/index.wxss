.mx-lg {
  margin-left: var(--spacing-lg);
  margin-right: var(--spacing-lg);
}

.home-hero {
  margin: var(--spacing-lg);
  padding: 36rpx 32rpx 32rpx;
  border-radius: 32rpx;
  background: linear-gradient(145deg, #edf9f2 0%, #c8edda 100%);
  box-shadow: 0 4rpx 24rpx rgba(7, 193, 96, 0.1);
}

.home-hero__head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
}

.home-hero__left {
  flex: 1;
  min-width: 0;
}

.home-hero__eyebrow {
  display: inline-block;
  padding: 8rpx 22rpx;
  border-radius: 999rpx;
  background: rgba(7, 193, 96, 0.18);
  font-size: 22rpx;
  color: #06a050;
  font-weight: 500;
}

.home-hero__title {
  margin-top: 18rpx;
  font-size: 40rpx;
  line-height: 1.3;
  font-weight: 700;
  color: #1a3d2b;
}

.home-hero__art {
  width: 160rpx;
  height: 160rpx;
  flex-shrink: 0;
}

.home-hero__desc {
  margin-top: 20rpx;
  font-size: 26rpx;
  line-height: 1.8;
  color: #4a7060;
}

.home-intro-list {
  margin-top: 28rpx;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.home-intro-item {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
}

.home-intro-item__dot {
  margin-top: 10rpx;
  width: 16rpx;
  height: 16rpx;
  border-radius: 999rpx;
  background: #07c160;
  flex-shrink: 0;
}

.home-intro-item__body {
  flex: 1;
  min-width: 0;
}

.home-intro-item__title {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #1a3d2b;
}

.home-intro-item__desc {
  display: block;
  margin-top: 6rpx;
  font-size: 24rpx;
  line-height: 1.7;
  color: #6a8878;
}
