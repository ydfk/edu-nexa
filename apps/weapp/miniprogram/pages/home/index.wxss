.mx-lg {
  margin-left: var(--spacing-lg);
  margin-right: var(--spacing-lg);
}

.home-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: var(--spacing-lg);
  padding-top: var(--spacing-xl);
}

.home-greeting {
  flex: 1;
}

.home-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: var(--color-primary-light);
  display: flex;
  align-items: center;
  justify-content: center;
}

.home-shortcuts {
  display: flex;
  flex-wrap: wrap;
  gap: var(--spacing-md);
}

.home-shortcut {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 120rpx;
}

.home-shortcut__icon {
  width: 88rpx;
  height: 88rpx;
  border-radius: var(--radius-md);
  display: flex;
  align-items: center;
  justify-content: center;
}

.home-shortcut__label {
  margin-top: var(--spacing-xs);
  font-size: 22rpx;
  color: var(--color-text);
  text-align: center;
}
