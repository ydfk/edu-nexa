<view class="page">
  <van-cell-group inset>
    <van-cell
      wx:if="{{canEdit}}"
      title="新增学生"
      is-link
      bind:click="handleCreateStudent"
    />
  </van-cell-group>

  <van-tabs
    wx:if="{{students.length > 0}}"
    custom-class="block-gap"
    active="{{activeStudentTab}}"
    swipeable
    animated
    bind:change="handleStudentTabChange"
  >
    <block wx:for="{{students}}" wx:key="id">
      <van-tab title="{{item.name}}" />
    </block>
  </van-tabs>

  <van-panel
    wx:if="{{!canEdit && students.length > 0}}"
    custom-class="block-gap"
    title="{{students[activeStudentTab].name}}"
    desc="{{students[activeStudentTab].schoolName}} {{students[activeStudentTab].className}}"
  >
    <van-cell-group border="{{false}}">
      <van-cell title="校区" value="{{students[activeStudentTab].campusName || '-'}}" />
      <van-cell title="监护人" value="{{students[activeStudentTab].guardianName || '-'}}" />
      <van-cell title="手机号" value="{{students[activeStudentTab].guardianPhone || '-'}}" />
    </van-cell-group>
  </van-panel>

  <view class="block-gap" wx:if="{{students.length === 0 && !canEdit}}">
    <van-empty description="无" />
  </view>

  <view wx:if="{{canEdit && draft && serviceDraft}}">
    <van-cell-group custom-class="block-gap" inset>
      <van-cell
        title="校区"
        value="{{campuses[draft.campusIndex] ? campuses[draft.campusIndex].name : '-'}}"
        is-link
        bind:click="handleOpenCampusPicker"
      />
      <van-field
        label="姓名"
        value="{{draft.name}}"
        data-field="name"
        placeholder="姓名"
        bind:change="handleFieldInput"
      />
      <van-field
        label="学校"
        value="{{draft.schoolName}}"
        data-field="schoolName"
        placeholder="学校"
        bind:change="handleFieldInput"
      />
      <van-field
        label="班级"
        value="{{draft.className}}"
        data-field="className"
        placeholder="班级"
        bind:change="handleFieldInput"
      />
      <van-field
        label="年级"
        value="{{draft.grade}}"
        data-field="grade"
        placeholder="年级"
        bind:change="handleFieldInput"
      />
      <van-field
        label="监护人"
        value="{{draft.guardianName}}"
        data-field="guardianName"
        placeholder="监护人"
        bind:change="handleFieldInput"
      />
      <van-field
        label="手机号"
        type="number"
        value="{{draft.guardianPhone}}"
        data-field="guardianPhone"
        placeholder="手机号"
        bind:change="handleFieldInput"
      />
    </van-cell-group>

    <van-radio-group
      custom-class="block-gap"
      value="{{serviceDraft.paymentStatus}}"
      bind:change="handlePaymentStatusChange"
    >
      <van-cell-group inset>
        <van-cell clickable data-name="paid" bind:click="handlePaymentStatusChange">
          <view slot="title">已缴费</view>
          <van-radio name="paid" slot="right-icon" />
        </van-cell>
        <van-cell clickable data-name="unpaid" bind:click="handlePaymentStatusChange">
          <view slot="title">待缴费</view>
          <van-radio name="unpaid" slot="right-icon" />
        </van-cell>
        <van-cell clickable data-name="paused" bind:click="handlePaymentStatusChange">
          <view slot="title">已暂停</view>
          <van-radio name="paused" slot="right-icon" />
        </van-cell>
      </van-cell-group>
    </van-radio-group>

    <van-cell-group custom-class="block-gap" inset>
      <van-cell
        title="缴费时间"
        value="{{serviceDraft.paidAt || '-'}}"
        is-link
        data-field="paidAt"
        bind:click="handleOpenDateCalendar"
      />
      <van-cell
        title="开始日期"
        value="{{serviceDraft.serviceStartDate || '-'}}"
        is-link
        data-field="serviceStartDate"
        bind:click="handleOpenDateCalendar"
      />
      <van-cell
        title="结束日期"
        value="{{serviceDraft.serviceEndDate || '-'}}"
        is-link
        data-field="serviceEndDate"
        bind:click="handleOpenDateCalendar"
      />
      <van-field
        label="备注"
        type="textarea"
        autosize
        value="{{serviceDraft.remark}}"
        data-field="remark"
        placeholder="备注"
        bind:change="handleServiceFieldInput"
      />
    </van-cell-group>

    <van-submit-bar
      button-text="保存"
      custom-class="submit-bar"
      safe-area-inset-bottom
      bind:submit="handleSave"
    />
  </view>

  <van-popup
    show="{{showCampusPicker}}"
    position="bottom"
    round
    bind:close="handleCloseCampusPicker"
  >
    <van-picker
      columns="{{campusColumns}}"
      show-toolbar
      value-key="text"
      bind:cancel="handleCloseCampusPicker"
      bind:confirm="handleConfirmCampus"
    />
  </van-popup>

  <van-calendar
    show="{{showDateCalendar}}"
    color="#07c160"
    poppable
    bind:close="handleCloseDateCalendar"
    bind:confirm="handleConfirmDate"
  />
</view>
