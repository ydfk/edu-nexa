<view class="page">
  <view class="hero">
    <view class="hero-title">把作业状态和反馈一次记录完整。</view>
    <view class="hero-subtitle">后续可直接扩展图片、语音和常用短语模板。</view>
  </view>

  <view class="section">
    <view class="section-title">今日作业反馈</view>
    <view class="list">
      <block wx:for="{{records}}" wx:key="studentName">
        <view class="list-item">
          <view class="list-title">{{item.studentName}}</view>
          <view class="tag">{{item.status}}</view>
          <view class="list-meta">{{item.remark}}</view>
        </view>
      </block>
    </view>
  </view>
</view>
