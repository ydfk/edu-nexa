<view class="page">
  <van-cell-group inset>
    <van-cell
      title="日期"
      value="{{selectedDate}}"
      is-link
      bind:click="handleOpenDateCalendar"
    />
  </van-cell-group>

  <van-tabs
    wx:if="{{canManage}}"
    custom-class="block-gap"
    active="{{managerMode}}"
    bind:change="handleManagerModeChange"
  >
    <van-tab title="每日作业" name="assignment" />
    <van-tab title="完成情况" name="feedback" />
  </van-tabs>

  <van-tabs
    wx:if="{{canManage && managerMode === 'assignment' && assignments.length > 0}}"
    custom-class="block-gap"
    active="{{activeAssignmentTab}}"
    swipeable
    animated
    bind:change="handleAssignmentTabChange"
  >
    <block wx:for="{{assignments}}" wx:key="id">
      <van-tab title="{{item.className || item.schoolName}}" />
    </block>
  </van-tabs>

  <van-panel
    wx:if="{{canManage && managerMode === 'assignment' && assignmentDraft}}"
    custom-class="block-gap"
    title="{{assignmentDraft.schoolName}}"
    desc="{{assignmentDraft.className}}"
    status="{{assignmentDraft.studentCount}}人"
  >
    <van-cell-group border="{{false}}">
      <van-field
        label="作业"
        type="textarea"
        autosize
        value="{{assignmentDraft.content}}"
        placeholder="作业"
        bind:change="handleAssignmentContentInput"
      />
      <van-field
        label="备注"
        type="textarea"
        autosize
        value="{{assignmentDraft.remark}}"
        placeholder="备注"
        bind:change="handleAssignmentRemarkInput"
      />
    </van-cell-group>
  </van-panel>

  <van-tabs
    wx:if="{{(!canManage || managerMode === 'feedback') && students.length > 0}}"
    custom-class="block-gap"
    active="{{activeStudentTab}}"
    swipeable
    animated
    bind:change="handleStudentTabChange"
  >
    <block wx:for="{{students}}" wx:key="id">
      <van-tab title="{{item.name}}" />
    </block>
  </van-tabs>

  <van-panel
    wx:if="{{(!canManage || managerMode === 'feedback') && currentRecord}}"
    custom-class="block-gap"
    title="{{currentRecord.studentName}}"
    desc="{{currentRecord.schoolName}} {{currentRecord.className}}"
    status="{{currentRecord.statusLabel}}"
  >
    <van-cell-group border="{{false}}">
      <van-cell title="每日作业" value="{{currentRecord.assignmentContent ? '已录入' : '-'}}" />
      <van-field
        wx:if="{{currentRecord.assignmentContent}}"
        label="内容"
        readonly
        type="textarea"
        autosize
        value="{{currentRecord.assignmentContent}}"
      />
      <van-field
        wx:if="{{currentRecord.assignmentRemark}}"
        label="备注"
        readonly
        type="textarea"
        autosize
        value="{{currentRecord.assignmentRemark}}"
      />
    </van-cell-group>
  </van-panel>

  <view wx:if="{{canManage && managerMode === 'feedback' && homeworkEditorDraft}}">
    <van-radio-group
      custom-class="block-gap"
      value="{{homeworkEditorDraft.status}}"
      bind:change="handleHomeworkStatusChange"
    >
      <van-cell-group inset>
        <van-cell clickable data-name="pending" bind:click="handleHomeworkStatusChange">
          <view slot="title">待处理</view>
          <van-radio name="pending" slot="right-icon" />
        </van-cell>
        <van-cell clickable data-name="completed" bind:click="handleHomeworkStatusChange">
          <view slot="title">已完成</view>
          <van-radio name="completed" slot="right-icon" />
        </van-cell>
        <van-cell clickable data-name="partial" bind:click="handleHomeworkStatusChange">
          <view slot="title">完成一部分</view>
          <van-radio name="partial" slot="right-icon" />
        </van-cell>
      </van-cell-group>
    </van-radio-group>

    <van-cell-group custom-class="block-gap" inset>
      <van-field
        label="备注"
        type="textarea"
        autosize
        value="{{homeworkEditorDraft.remark}}"
        placeholder="备注"
        bind:change="handleHomeworkRemarkInput"
      />
    </van-cell-group>

    <van-uploader
      custom-class="block-gap uploader-block"
      file-list="{{homeworkEditorDraft.fileList}}"
      multiple
      max-count="3"
      preview-full-image
      bind:after-read="handleAfterReadImage"
      bind:delete="handleDeleteImage"
    />

    <van-submit-bar
      button-text="保存"
      custom-class="submit-bar"
      safe-area-inset-bottom
      bind:submit="handleSaveHomeworkRecord"
    />
  </view>

  <van-cell-group
    wx:if="{{!canManage && currentRecord}}"
    custom-class="block-gap"
    inset
  >
    <van-field label="完成情况" readonly value="{{currentRecord.statusLabel}}" />
    <van-field
      label="备注"
      readonly
      type="textarea"
      autosize
      value="{{currentRecord.remark || '-'}}"
    />
  </van-cell-group>

  <van-uploader
    wx:if="{{!canManage && currentRecord && currentRecord.fileList.length > 0}}"
    custom-class="block-gap uploader-block"
    file-list="{{currentRecord.fileList}}"
    preview-full-image
    show-upload="{{false}}"
    deletable="{{false}}"
  />

  <view wx:if="{{canManage && managerMode === 'assignment' && assignmentDraft}}">
    <van-submit-bar
      button-text="保存"
      custom-class="submit-bar"
      safe-area-inset-bottom
      bind:submit="handleSaveAssignment"
    />
  </view>

  <view class="block-gap" wx:if="{{students.length === 0 && assignments.length === 0}}">
    <van-empty description="无" />
  </view>

  <van-calendar
    show="{{showDateCalendar}}"
    color="#07c160"
    poppable
    bind:close="handleCloseDateCalendar"
    bind:confirm="handleConfirmDate"
  />
</view>
