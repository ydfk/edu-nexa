@import "miniprogram_npm/@vant/weapp/common/index.wxss";

/* ========== 设计系统 ========== */

page {
  --color-primary: #07C160;
  --color-primary-dark: #06ad56;
  --color-primary-light: #e8f8ef;
  --color-info: #1989FA;
  --color-info-light: #e8f3ff;
  --color-warning: #FF976A;
  --color-warning-light: #fff3ec;
  --color-danger: #EE0A24;
  --color-danger-light: #fff0f0;
  --color-success: #07C160;
  --color-success-light: #e8f8ef;

  --color-bg: #F7F8FA;
  --color-bg-card: #FFFFFF;
  --color-bg-secondary: #F2F3F5;

  --color-text: #323233;
  --color-text-secondary: #969799;
  --color-text-placeholder: #C8C9CC;
  --color-border: #EBEDF0;

  --radius-sm: 8rpx;
  --radius-md: 16rpx;
  --radius-lg: 24rpx;
  --radius-full: 999rpx;

  --shadow-card: 0 4rpx 16rpx rgba(0, 0, 0, 0.04);
  --shadow-float: 0 8rpx 32rpx rgba(0, 0, 0, 0.08);

  --spacing-xs: 8rpx;
  --spacing-sm: 16rpx;
  --spacing-md: 24rpx;
  --spacing-lg: 32rpx;
  --spacing-xl: 48rpx;

  background: var(--color-bg);
  color: var(--color-text);
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Microsoft YaHei", sans-serif;
  font-size: 28rpx;
  line-height: 1.5;
}

/* ========== 页面容器 ========== */

.page {
  min-height: 100vh;
  padding: var(--spacing-lg);
  box-sizing: border-box;
}

.page--no-pad {
  padding: 0;
}

.safe-bottom {
  padding-bottom: calc(env(safe-area-inset-bottom) + 120rpx);
}

/* ========== 卡片 ========== */

.card {
  padding: var(--spacing-lg);
  border-radius: var(--radius-lg);
  background: var(--color-bg-card);
  box-shadow: var(--shadow-card);
}

.card + .card {
  margin-top: var(--spacing-md);
}

.card--flat {
  box-shadow: none;
  border: 2rpx solid var(--color-border);
}

/* ========== 区块 ========== */

.section {
  margin-top: var(--spacing-md);
  padding: var(--spacing-lg);
  border-radius: var(--radius-lg);
  background: var(--color-bg-card);
  box-shadow: var(--shadow-card);
}

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: var(--spacing-md);
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--color-text);
}

.section-more {
  font-size: 24rpx;
  color: var(--color-text-secondary);
}

/* ========== 网格布局 ========== */

.grid-2 {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: var(--spacing-md);
}

.grid-3 {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: var(--spacing-md);
}

.grid-4 {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: var(--spacing-sm);
}

/* ========== KPI 卡片 ========== */

.kpi-card {
  padding: var(--spacing-md);
  border-radius: var(--radius-md);
  background: var(--color-bg-secondary);
}

.kpi-label {
  font-size: 24rpx;
  color: var(--color-text-secondary);
}

.kpi-value {
  margin-top: var(--spacing-xs);
  font-size: 44rpx;
  font-weight: 700;
  color: var(--color-text);
}

.kpi-card--primary {
  background: var(--color-primary-light);
}

.kpi-card--primary .kpi-value {
  color: var(--color-primary);
}

.kpi-card--info {
  background: var(--color-info-light);
}

.kpi-card--info .kpi-value {
  color: var(--color-info);
}

.kpi-card--warning {
  background: var(--color-warning-light);
}

.kpi-card--warning .kpi-value {
  color: var(--color-warning);
}

/* ========== 列表 ========== */

.list {
  display: flex;
  flex-direction: column;
  gap: var(--spacing-sm);
}

.list-item {
  display: flex;
  align-items: center;
  padding: var(--spacing-md);
  border-radius: var(--radius-md);
  background: var(--color-bg-secondary);
}

.list-item--clickable {
  position: relative;
}

.list-item--clickable::after {
  content: "";
  position: absolute;
  right: var(--spacing-md);
  top: 50%;
  transform: translateY(-50%) rotate(45deg);
  width: 16rpx;
  height: 16rpx;
  border-top: 3rpx solid var(--color-text-placeholder);
  border-right: 3rpx solid var(--color-text-placeholder);
}

.list-content {
  flex: 1;
  min-width: 0;
}

.list-title {
  font-size: 28rpx;
  font-weight: 500;
  color: var(--color-text);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.list-desc {
  margin-top: 4rpx;
  font-size: 24rpx;
  color: var(--color-text-secondary);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* ========== 标签 ========== */

.tag {
  display: inline-flex;
  align-items: center;
  padding: 4rpx 16rpx;
  border-radius: var(--radius-full);
  font-size: 22rpx;
  font-weight: 500;
}

.tag--success {
  background: var(--color-success-light);
  color: var(--color-success);
}

.tag--warning {
  background: var(--color-warning-light);
  color: var(--color-warning);
}

.tag--danger {
  background: var(--color-danger-light);
  color: var(--color-danger);
}

.tag--info {
  background: var(--color-info-light);
  color: var(--color-info);
}

.tag--default {
  background: var(--color-bg-secondary);
  color: var(--color-text-secondary);
}

/* ========== 按钮 ========== */

.btn {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 88rpx;
  border-radius: var(--radius-md);
  font-size: 30rpx;
  font-weight: 500;
  border: none;
}

.btn::after {
  border: none;
}

.btn--primary {
  background: var(--color-primary);
  color: #fff;
}

.btn--primary:active {
  background: var(--color-primary-dark);
}

.btn--outline {
  background: transparent;
  color: var(--color-primary);
  border: 2rpx solid var(--color-primary);
}

.btn--ghost {
  background: var(--color-bg-secondary);
  color: var(--color-text);
}

.btn--danger {
  background: var(--color-danger);
  color: #fff;
}

.btn--small {
  height: 64rpx;
  padding: 0 24rpx;
  font-size: 26rpx;
  border-radius: var(--radius-sm);
}

.btn--round {
  border-radius: var(--radius-full);
}

.btn--block {
  width: 100%;
}

/* ========== FAB 浮动按钮 ========== */

.fab {
  position: fixed;
  right: var(--spacing-lg);
  bottom: calc(env(safe-area-inset-bottom) + 180rpx);
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: var(--color-primary);
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: var(--shadow-float);
  z-index: 100;
}

.fab-icon {
  font-size: 48rpx;
  font-weight: 300;
}

/* ========== 日期导航 ========== */

.date-nav {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: var(--spacing-sm) var(--spacing-md);
  background: var(--color-bg-card);
  border-radius: var(--radius-md);
}

.date-nav__arrow {
  padding: var(--spacing-xs) var(--spacing-sm);
  font-size: 32rpx;
  color: var(--color-text-secondary);
}

.date-nav__text {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--color-text);
}

/* ========== 表单 ========== */

.form-group {
  margin-bottom: var(--spacing-md);
}

.form-label {
  margin-bottom: var(--spacing-xs);
  font-size: 26rpx;
  font-weight: 500;
  color: var(--color-text);
}

.form-label--required::before {
  content: "*";
  color: var(--color-danger);
  margin-right: 4rpx;
}

.form-input {
  width: 100%;
  height: 88rpx;
  padding: 0 var(--spacing-md);
  box-sizing: border-box;
  border-radius: var(--radius-md);
  background: var(--color-bg-secondary);
  font-size: 28rpx;
  color: var(--color-text);
}

.form-textarea {
  width: 100%;
  min-height: 200rpx;
  padding: var(--spacing-md);
  box-sizing: border-box;
  border-radius: var(--radius-md);
  background: var(--color-bg-secondary);
  font-size: 28rpx;
  color: var(--color-text);
  line-height: 1.6;
}

/* ========== 搜索栏 ========== */

.search-bar {
  padding: var(--spacing-sm) var(--spacing-lg);
  background: var(--color-bg-card);
}

/* ========== 空状态 ========== */

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: var(--spacing-xl) 0;
  color: var(--color-text-placeholder);
}

.empty-state__text {
  margin-top: var(--spacing-sm);
  font-size: 28rpx;
  color: var(--color-text-secondary);
}

/* ========== 图片网格 ========== */

.image-grid {
  display: flex;
  flex-wrap: wrap;
  gap: var(--spacing-sm);
  margin-top: var(--spacing-sm);
}

.image-grid__item {
  position: relative;
  width: 160rpx;
  height: 160rpx;
  border-radius: var(--radius-md);
  overflow: hidden;
}

.image-grid__item image {
  width: 100%;
  height: 100%;
}

.image-grid__remove {
  position: absolute;
  top: 0;
  right: 0;
  width: 36rpx;
  height: 36rpx;
  background: rgba(0, 0, 0, 0.5);
  color: #fff;
  font-size: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 0 0 0 var(--radius-sm);
}

/* ========== 工具类 ========== */

.flex { display: flex; }
.flex-col { flex-direction: column; }
.flex-center { align-items: center; justify-content: center; }
.flex-between { align-items: center; justify-content: space-between; }
.flex-1 { flex: 1; min-width: 0; }
.flex-wrap { flex-wrap: wrap; }
.gap-xs { gap: var(--spacing-xs); }
.gap-sm { gap: var(--spacing-sm); }
.gap-md { gap: var(--spacing-md); }

.text-primary { color: var(--color-primary); }
.text-secondary { color: var(--color-text-secondary); }
.text-danger { color: var(--color-danger); }
.text-warning { color: var(--color-warning); }

.text-xs { font-size: 22rpx; }
.text-sm { font-size: 24rpx; }
.text-base { font-size: 28rpx; }
.text-lg { font-size: 32rpx; }
.text-xl { font-size: 36rpx; }
.text-2xl { font-size: 44rpx; }

.font-medium { font-weight: 500; }
.font-bold { font-weight: 600; }

.mt-xs { margin-top: var(--spacing-xs); }
.mt-sm { margin-top: var(--spacing-sm); }
.mt-md { margin-top: var(--spacing-md); }
.mt-lg { margin-top: var(--spacing-lg); }

.mb-sm { margin-bottom: var(--spacing-sm); }
.mb-md { margin-bottom: var(--spacing-md); }

.p-md { padding: var(--spacing-md); }
.p-lg { padding: var(--spacing-lg); }
.px-lg { padding-left: var(--spacing-lg); padding-right: var(--spacing-lg); }

.truncate {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.rounded { border-radius: var(--radius-md); }
.rounded-lg { border-radius: var(--radius-lg); }
.rounded-full { border-radius: var(--radius-full); }
