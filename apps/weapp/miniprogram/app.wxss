@import "miniprogram_npm/@vant/weapp/common/index.wxss";

page {
  background: #f4f7fb;
  color: #1f2f45;
  font-family: "PingFang SC", "Microsoft YaHei", sans-serif;
}

.page {
  min-height: 100vh;
  padding: 32rpx;
  box-sizing: border-box;
}

.hero {
  padding: 32rpx;
  border-radius: 28rpx;
  background: linear-gradient(135deg, #07c160, #06ae56);
  color: #ffffff;
  box-shadow: 0 18rpx 48rpx rgba(7, 193, 96, 0.18);
}

.hero-title {
  font-size: 40rpx;
  font-weight: 600;
  line-height: 1.4;
}

.hero-subtitle {
  margin-top: 16rpx;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
}

.hero-meta {
  margin-top: 12rpx;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.72);
}

.section {
  margin-top: 24rpx;
  padding: 28rpx;
  border-radius: 24rpx;
  background: #ffffff;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
}

.grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 20rpx;
  margin-top: 24rpx;
}

.card {
  padding: 24rpx;
  border-radius: 24rpx;
  background: #f7f9fd;
}

.card-label {
  font-size: 22rpx;
  color: #6b7b91;
}

.card-value {
  margin-top: 12rpx;
  font-size: 38rpx;
  font-weight: 600;
}

.list {
  margin-top: 20rpx;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.list-item {
  padding: 24rpx;
  border-radius: 20rpx;
  background: #f7f9fd;
}

.list-item.is-clickable {
  border: 2rpx solid transparent;
}

.list-title {
  font-size: 28rpx;
  font-weight: 600;
}

.list-meta {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #6b7b91;
}

.tag {
  display: inline-flex;
  margin-top: 12rpx;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: #e8fbef;
  color: #06ae56;
  font-size: 22rpx;
}

.helper-text {
  margin-top: 16rpx;
  font-size: 22rpx;
  color: #6b7b91;
  line-height: 1.7;
}

.action-button {
  margin-top: 20rpx;
  border-radius: 999rpx;
  background: #07c160;
  color: #ffffff;
  font-size: 26rpx;
}

.action-button.secondary {
  background: #e8fbef;
  color: #06ae56;
}

.action-button.ghost {
  background: transparent;
  color: #6b7b91;
  border: 2rpx solid #d7e1ef;
}

.toolbar {
  margin-top: 20rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.mini-button {
  margin: 0;
  min-width: 148rpx;
  padding: 0 24rpx;
  border-radius: 999rpx;
  background: #e8fbef;
  color: #06ae56;
  font-size: 24rpx;
}

.date-chip {
  flex: 1;
  text-align: center;
  font-size: 26rpx;
  font-weight: 600;
  color: #1f2f45;
}

.chip-scroll {
  margin-top: 20rpx;
  white-space: nowrap;
}

.chip-row {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-top: 20rpx;
}

.student-chip {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 14rpx 24rpx;
  border-radius: 999rpx;
  background: #e8fbef;
  color: #4d6280;
  font-size: 24rpx;
}

.student-chip-active {
  background: #07c160;
  color: #ffffff;
}

.row-between {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
}

.switch-row {
  margin-top: 20rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.picker-field {
  margin-top: 20rpx;
  padding: 22rpx 24rpx;
  border-radius: 18rpx;
  background: #f0fbf4;
  color: #1f2f45;
  font-size: 26rpx;
}

.editor-textarea {
  width: 100%;
  min-height: 176rpx;
  margin-top: 20rpx;
  padding: 20rpx 22rpx;
  box-sizing: border-box;
  border-radius: 18rpx;
  background: #f0fbf4;
  color: #1f2f45;
  font-size: 26rpx;
  line-height: 1.6;
}

.editor-textarea.compact {
  min-height: 120rpx;
}

.empty-card {
  margin-top: 20rpx;
  padding: 28rpx;
  border-radius: 20rpx;
  background: #f7f9fd;
  color: #6b7b91;
  font-size: 24rpx;
}

.banner-swiper {
  height: 280rpx;
  margin-top: 20rpx;
}

.banner-card {
  display: flex;
  height: 100%;
  overflow: hidden;
  border-radius: 24rpx;
  background: #f7f9fd;
}

.banner-image {
  width: 240rpx;
  height: 100%;
  background: #d7f5e4;
}

.banner-content {
  flex: 1;
  padding: 28rpx 24rpx;
  box-sizing: border-box;
}

.image-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-top: 20rpx;
}

.image-card {
  position: relative;
}

.record-image {
  width: 160rpx;
  height: 160rpx;
  border-radius: 18rpx;
  background: #d7f5e4;
}

.image-remove {
  position: absolute;
  right: 8rpx;
  bottom: 8rpx;
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
  background: rgba(32, 50, 40, 0.76);
  color: #ffffff;
  font-size: 20rpx;
}
