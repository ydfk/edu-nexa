page {
  background: #f6f8f5;
  color: #203228;
  font-family: "PingFang SC", "Microsoft YaHei", sans-serif;
}

.page {
  min-height: 100vh;
  padding: 32rpx;
  box-sizing: border-box;
}

.hero {
  padding: 32rpx;
  border-radius: 28rpx;
  background: linear-gradient(135deg, #2f8d66, #1d5b45);
  color: #ffffff;
  box-shadow: 0 18rpx 48rpx rgba(28, 90, 68, 0.18);
}

.hero-title {
  font-size: 40rpx;
  font-weight: 600;
  line-height: 1.4;
}

.hero-subtitle {
  margin-top: 16rpx;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
}

.section {
  margin-top: 24rpx;
  padding: 28rpx;
  border-radius: 24rpx;
  background: #ffffff;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
}

.grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 20rpx;
  margin-top: 24rpx;
}

.card {
  padding: 24rpx;
  border-radius: 24rpx;
  background: #f8faf8;
}

.card-label {
  font-size: 22rpx;
  color: #637469;
}

.card-value {
  margin-top: 12rpx;
  font-size: 38rpx;
  font-weight: 600;
}

.list {
  margin-top: 20rpx;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.list-item {
  padding: 24rpx;
  border-radius: 20rpx;
  background: #f8faf8;
}

.list-title {
  font-size: 28rpx;
  font-weight: 600;
}

.list-meta {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #637469;
}

.tag {
  display: inline-flex;
  margin-top: 12rpx;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: #e8f5ee;
  color: #1c7a57;
  font-size: 22rpx;
}

.helper-text {
  margin-top: 16rpx;
  font-size: 22rpx;
  color: #637469;
  line-height: 1.7;
}

.action-button {
  margin-top: 20rpx;
  border-radius: 999rpx;
  background: #1c7a57;
  color: #ffffff;
  font-size: 26rpx;
}

.action-button.secondary {
  background: #eff4f1;
  color: #1c7a57;
}
