{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "moduleDetection": "force",
    "strict": false,
    "noImplicitAny": false,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "types": [
      "miniprogram-api-typings",
      "node"
    ]
  },
  "include": [
    "miniprogram/**/*.ts"
  ]
}
